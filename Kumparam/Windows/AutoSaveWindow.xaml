<Window x:Class="Kumparam.Windows.AutoSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Otomatik Birikim" Height="330" Width="350" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <StackPanel Margin="20">
        <TextBlock Text="Otomatik Birikim Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBox x:Name="AmountTextBox" materialDesign:HintAssist.Hint="Aktarılacak Tutar (₺)" Margin="0,10"/>

        <ComboBox x:Name="FrequencyComboBox" materialDesign:HintAssist.Hint="Tekrarlama Sıklığı" Margin="0,10">
            <ComboBoxItem Content="Her Gün" Tag="Daily"/>
            <ComboBoxItem Content="Her Hafta" Tag="Weekly"/>
            <ComboBoxItem Content="Her Ay" Tag="Monthly" IsSelected="True"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="SİL / İPTAL" Style="{StaticResource MaterialDesignOutlinedButton}" 
                    Foreground="#EF5350" BorderBrush="#EF5350" Click="Cancel_Click" Margin="0,0,10,0"/>
            <Button Content="KAYDET" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>