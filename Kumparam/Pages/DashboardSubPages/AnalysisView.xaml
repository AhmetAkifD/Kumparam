<UserControl x:Class="Kumparam.Pages.DashboardSubPages.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1030"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Kontrol Paneli -->
            <RowDefinition Height="*"/>    <!-- Grafikler -->
        </Grid.RowDefinitions>

        <!-- 1. KONTROL PANELİ (Görünüm Seçimi) -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,20" Padding="15" UniformCornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Görüntülenecek Analizler:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Toggle Butonları -->
                <CheckBox x:Name="TogglePie" Content="Harcama Pastası" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked"
                          Margin="0,0,10,0"/>
                
                <CheckBox x:Name="ToggleBar" Content="Gelir/Gider Sütunları" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked"
                          Margin="0,0,10,0"/>
                
                <CheckBox x:Name="ToggleLine" Content="Varlık Trendi" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked"
                          Margin="0,0,10,0"/>

                <!-- YENİ: Günlük Analiz Toggle -->
                <CheckBox x:Name="ToggleDays" Content="Günlük Alışkanlıklar" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- 2. GRAFİK ALANI (Scroll Edilebilir) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ChartsPanel">
                
                <!-- A. PASTA GRAFİK KARTI -->
                <materialDesign:Card x:Name="CardPie" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Harcama Dağılımı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Kategorilere göre giderler" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                    Click="CloseCard_Click" Tag="Pie" ToolTip="Gizle">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </DockPanel>

                        <ContentControl x:Name="PieChartContainer" Grid.Row="1" Margin="10"/>
                        <TextBlock x:Name="TxtNoPieData" Grid.Row="1" Text="Veri Yok" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Visibility="Collapsed" Opacity="0.5"/>
                    </Grid>
                </materialDesign:Card>

                <!-- B. SÜTUN GRAFİK KARTI -->
                <materialDesign:Card x:Name="CardBar" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Son 6 Ayın Özeti" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Aylık Gelir ve Gider Karşılaştırması" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                    Click="CloseCard_Click" Tag="Bar" ToolTip="Gizle">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </DockPanel>

                        <ContentControl x:Name="BarChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- C. ÇİZGİ GRAFİK KARTI -->
                <materialDesign:Card x:Name="CardLine" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Varlık Gelişimi" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Toplam bakiyenizin zaman içindeki değişimi" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                    Click="CloseCard_Click" Tag="Line" ToolTip="Gizle">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </DockPanel>

                        <ContentControl x:Name="LineChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- D. YENİ: GÜNLÜK ANALİZ KARTI -->
                <materialDesign:Card x:Name="CardDays" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Haftalık Harcama Alışkanlıkları" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Hangi günlerde daha çok harcama yapıyorsunuz?" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                    Click="CloseCard_Click" Tag="Days" ToolTip="Gizle">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </DockPanel>

                        <ContentControl x:Name="DaysChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>