<UserControl x:Class="Kumparam.Pages.DashboardSubPages.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="1600" d:DesignWidth="1030"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Kontrol Paneli -->
            <RowDefinition Height="*"/>    <!-- Grafikler -->
        </Grid.RowDefinitions>

        <!-- 1. KONTROL PANELİ -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,20" Padding="15" UniformCornerRadius="8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Görüntüle:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <CheckBox x:Name="TogglePie" Content="Harcama Pastası" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                
                <CheckBox x:Name="ToggleBar" Content="6 Aylık Özet" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                
                <CheckBox x:Name="ToggleLine" Content="Varlık Trendi" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                <CheckBox x:Name="ToggleDays" Content="Haftalık Alışkanlık" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                <!-- YENİLER -->
                <CheckBox x:Name="ToggleStacked" Content="Aylık Kategori Detayı" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                <CheckBox x:Name="ToggleWaterfall" Content="Bu Ayın Bütçe Akışı" 
                          Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                          IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="#D32F2F" BorderBrush="#D32F2F"
                        Click="DownloadPdf_Click" 
                        Margin="20,0,0,0" Height="30" FontSize="12" Padding="10,0">
                    <!-- Butonun içeriği tek bir StackPanel -->
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PDF İNDİR"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </materialDesign:Card>

        <!-- 2. GRAFİK ALANI -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ChartsPanel">
                
                <!-- A. PASTA & SÜTUN (YAN YANA) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Pasta Grafik -->
                    <materialDesign:Card x:Name="CardPie" Grid.Column="0" Margin="0,0,10,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Margin="20,15,20,5" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Harcama Dağılımı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                    <TextBlock Text="Toplam harcamaların kategorilere oranı" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Pie"><materialDesign:PackIcon Kind="Close"/></Button>
                            </DockPanel>
                            <ContentControl x:Name="PieChartContainer" Grid.Row="1" Margin="10"/>
                            <TextBlock x:Name="TxtNoPieData" Grid.Row="1" Text="Veri Yok" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Opacity="0.5"/>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Sütun Grafik (6 Ay) -->
                    <materialDesign:Card x:Name="CardBar" Grid.Column="1" Margin="10,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Margin="20,15,20,5" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Son 6 Ayın Özeti" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                    <TextBlock Text="Aylık Gelir ve Gider Karşılaştırması" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Bar"><materialDesign:PackIcon Kind="Close"/></Button>
                            </DockPanel>
                            <ContentControl x:Name="BarChartContainer" Grid.Row="1" Margin="10"/>
                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <!-- B. YENİ: YIĞILMIŞ SÜTUN (AYLIK KATEGORİ DETAYI) -->
                <materialDesign:Card x:Name="CardStacked" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Aylık Gider Detayları" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Her ay hangi kategoriye ne kadar harcandı?" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Stacked"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="StackedChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- C. YENİ: WATERFALL (BÜTÇE AKIŞI) -->
                <materialDesign:Card x:Name="CardWaterfall" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Bu Ayın Bütçe Akışı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Gelirler, Giderler ve Kalan Bakiye" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Waterfall"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="WaterfallChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- D. ÇİZGİ GRAFİK (TREND) -->
                <materialDesign:Card x:Name="CardLine" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Varlık Gelişimi" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Toplam bakiyenizin zaman içindeki değişimi" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Line"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="LineChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- E. GÜNLÜK HARCAMA -->
                <materialDesign:Card x:Name="CardDays" Margin="0,0,0,20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="20,15,20,5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Haftalık Harcama Alışkanlıkları" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Hangi günlerde daha çok harcama yapıyorsunuz?" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Days"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="DaysChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>