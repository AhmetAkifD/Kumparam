<UserControl x:Class="Kumparam.Pages.DashboardSubPages.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="1800" d:DesignWidth="1030"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="5">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Görüntüle:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <CheckBox x:Name="TogglePie" Content="Harcama Dağılımı" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                    
                    <CheckBox x:Name="ToggleBar" Content="6 Aylık Özet" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                    
                    <CheckBox x:Name="ToggleLine" Content="Varlık Gelişimi" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                    <CheckBox x:Name="ToggleDays" Content="Haftalık Alışkanlık" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                    <CheckBox x:Name="ToggleStacked" Content="Aylık Gider" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                    <CheckBox x:Name="ToggleWaterfall" Content="Bütçe Akışı" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>

                    <CheckBox x:Name="ToggleBudget" Content="Bütçe Sağlığı" 
                              Style="{StaticResource MaterialDesignFilterChipCheckBox}" 
                              IsChecked="True" Checked="ToggleChart_Checked" Unchecked="ToggleChart_Unchecked" Margin="0,0,5,5"/>
                </WrapPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCardStyle}" Margin="5" VerticalAlignment="Stretch">
                <Grid VerticalAlignment="Center">
                    <Button Background="#D32F2F" BorderBrush="#D32F2F"
                            Click="DownloadPdf_Click" 
                            Height="36" MinWidth="120" FontSize="12" Padding="12,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FilePdfBox" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="PDF İNDİR"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ChartsPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card x:Name="CardPie" Grid.Row="0" Style="{StaticResource DashboardCardStyle}" Height="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Harcama Dağılımı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                    <TextBlock Text="Toplam harcamaların kategorilere oranı" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Pie"><materialDesign:PackIcon Kind="Close"/></Button>
                            </DockPanel>
                            <ContentControl x:Name="PieChartContainer" Grid.Row="1" Margin="10"/>
                            <TextBlock x:Name="TxtNoPieData" Grid.Row="1" Text="Veri Yok" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Opacity="0.5"/>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card x:Name="CardBar" Grid.Row="1" Style="{StaticResource DashboardCardStyle}" Height="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Son 6 Ayın Özeti" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                    <TextBlock Text="Aylık Gelir ve Gider Karşılaştırması" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Bar"><materialDesign:PackIcon Kind="Close"/></Button>
                            </DockPanel>
                            <ContentControl x:Name="BarChartContainer" Grid.Row="1" Margin="10"/>
                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <materialDesign:Card x:Name="CardBudget" Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="Auto"/> 
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
                            <StackPanel DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ScaleBalance" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Bütçe Sağlığı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                </StackPanel>
                                <TextBlock Text="Bu ayki harcamalarınızın gelire oranı" Opacity="0.6" FontSize="12" Margin="34,0,0,0"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Budget"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                <TextBlock Text="İhtiyaçlar" FontWeight="Bold" DockPanel.Dock="Left"/>
                                <TextBlock Text="İdeal: %50" Opacity="0.5" DockPanel.Dock="Right" FontSize="12"/>
                            </DockPanel>
                            
                            <Border Grid.Row="1" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="2" Height="25">
                                <Grid>
                                    <ProgressBar Value="50" Maximum="100" Background="Transparent" Foreground="{DynamicResource MaterialDesignDivider}" BorderBrush="Transparent" Height="25" Opacity="0.3"/>
                                    <ProgressBar x:Name="PbNeeds" Value="0" Maximum="100" Background="Transparent" Foreground="#66BB6A" BorderBrush="Transparent" Height="25"/>
                                    <TextBlock x:Name="TxtNeeds" Text="%0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" FontSize="12"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,15">
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                <TextBlock Text="İstekler" FontWeight="Bold" DockPanel.Dock="Left"/>
                                <TextBlock Text="İdeal: %30" Opacity="0.5" DockPanel.Dock="Right" FontSize="12"/>
                            </DockPanel>
                            
                            <Border Grid.Row="1" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="2" Height="25">
                                <Grid>
                                    <ProgressBar Value="30" Maximum="100" Background="Transparent" Foreground="{DynamicResource MaterialDesignDivider}" BorderBrush="Transparent" Height="25" Opacity="0.3"/>
                                    <ProgressBar x:Name="PbWants" Value="0" Maximum="100" Background="Transparent" Foreground="#FFA726" BorderBrush="Transparent" Height="25"/>
                                    <TextBlock x:Name="TxtWants" Text="%0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" FontSize="12"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,10">
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                <TextBlock Text="Birikim &amp; Yatırım" FontWeight="Bold" DockPanel.Dock="Left"/>
                                <TextBlock Text="İdeal: %20" Opacity="0.5" DockPanel.Dock="Right" FontSize="12"/>
                            </DockPanel>
                            
                            <Border Grid.Row="1" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="2" Height="25">
                                <Grid>
                                    <ProgressBar Value="20" Maximum="100" Background="Transparent" Foreground="{DynamicResource MaterialDesignDivider}" BorderBrush="Transparent" Height="25" Opacity="0.3"/>
                                    <ProgressBar x:Name="PbSavings" Value="0" Maximum="100" Background="Transparent" Foreground="#42A5F5" BorderBrush="Transparent" Height="25"/>
                                    <TextBlock x:Name="TxtSavings" Text="%0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" FontSize="12"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardStacked" Style="{StaticResource DashboardCardStyle}" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Aylık Gider Detayları" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Her ay hangi kategoriye ne kadar harcandı?" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Stacked"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="StackedChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardWaterfall" Style="{StaticResource DashboardCardStyle}" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Bu Ayın Bütçe Akışı" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Gelirler, Giderler ve Kalan Bakiye" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Waterfall"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="WaterfallChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardLine" Style="{StaticResource DashboardCardStyle}" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Varlık Gelişimi" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Toplam bakiyenizin zaman içindeki değişimi" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Line"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="LineChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardDays" Style="{StaticResource DashboardCardStyle}" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Haftalık Harcama Alışkanlıkları" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                                <TextBlock Text="Hangi günlerde daha çok harcama yapıyorsunuz?" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="CloseCard_Click" Tag="Days"><materialDesign:PackIcon Kind="Close"/></Button>
                        </DockPanel>
                        <ContentControl x:Name="DaysChartContainer" Grid.Row="1" Margin="10"/>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>