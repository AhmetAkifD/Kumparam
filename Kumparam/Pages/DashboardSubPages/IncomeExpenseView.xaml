<UserControl x:Class="Kumparam.Pages.DashboardSubPages.IncomeExpenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="2*"/>   </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Yeni İşlem Ekle" Style="{StaticResource HeaderTextStyle}"/>

                <ComboBox x:Name="TypeComboBox" materialDesign:HintAssist.Hint="İşlem Tipi Seçin" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,10">
                    <ComboBoxItem Content="Gelir" Tag="Income" Foreground="Green"/>
                    <ComboBoxItem Content="Gider" Tag="Expense" Foreground="Red"/>
                </ComboBox>

                <TextBox x:Name="AmountTextBox" materialDesign:HintAssist.Hint="Tutar (Örn: 150.50)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <TextBox x:Name="CategoryTextBox" materialDesign:HintAssist.Hint="Kategori (Örn: Market, Maaş)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <DatePicker x:Name="TransactionDatePicker" materialDesign:HintAssist.Hint="İşlem Tarihi" 
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,10"/>

                <TextBox x:Name="DescriptionTextBox" materialDesign:HintAssist.Hint="Açıklama (Opsiyonel)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"
                         Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         KeyDown="DescriptionTextBox_OnKeyDown"/>

                <Button Content="KAYDET" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="0,20,0,0" Height="50" Click="SaveButton_Click"/>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCardStyle}" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Son İşlemler Geçmişi" Style="{StaticResource HeaderTextStyle}"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <ItemsControl x:Name="TransactionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="ArrowDownBoldCircle"/>
                                                    <Setter Property="Foreground" Value="Red"/>
                                                        
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                            <Setter Property="Kind" Value="ArrowUpBoldCircle"/>
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6" 
                                                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat='-₺ {0:N2}'}"/>
                                                    <Setter Property="Foreground" Value="Red"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                            <Setter Property="Text" Value="{Binding Amount, StringFormat='+₺ {0:N2}'}"/>
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>        
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>