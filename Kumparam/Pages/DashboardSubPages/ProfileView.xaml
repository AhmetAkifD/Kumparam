<UserControl x:Class="Kumparam.Pages.DashboardSubPages.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel VerticalAlignment="Center" Margin="10">
                
                <Border Width="120" Height="120" CornerRadius="60" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,15">
                    <TextBlock x:Name="TxtInitials" Text="UK" FontSize="48" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TxtFullName" Text="Yükleniyor..." Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Bold"/>
                
                <TextBlock x:Name="TxtEmailDisplay" Text="user@mail.com" Style="{StaticResource MaterialDesignBody2TextBlock}" 
                           HorizontalAlignment="Center" Opacity="0.6" Margin="0,5,0,20"/>

                <Separator Margin="20,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <materialDesign:PackIcon Kind="WalletMembership" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource SecondaryHueMidBrush}" Width="24" Height="24"/>
    
                    <TextBlock x:Name="TxtUserRole" Text="Standart Üye" VerticalAlignment="Center" FontWeight="SemiBold" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>
                
                <materialDesign:Card Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <materialDesign:PackIcon Kind="AccountEdit" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Kişisel Bilgiler" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FirstNameTextBox" Grid.Column="0" materialDesign:HintAssist.Hint="Ad" Margin="0,0,10,0"/>
                            <TextBox x:Name="LastNameTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="Soyad" Margin="10,0,0,0"/>
                        </Grid>

                        <Button Content="BİLGİLERİ GÜNCELLE" Click="UpdateProfile_Click" 
                                Margin="0,15,0,0" 
                                HorizontalAlignment="Right" 
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Foreground="{DynamicResource MaterialDesignPaper}"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <materialDesign:PackIcon Kind="Tools" Width="24" Height="24" Foreground="#FFA726"/>
                            <TextBlock Text="Araçlar" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Grid>
                             <Button Style="{StaticResource MaterialDesignRaisedButton}" Height="50"
                                     Background="#FFA726"
                                     BorderBrush="#FFA726" 
                                     Foreground="{DynamicResource MaterialDesignPaper}" 
                                    Click="OpenRecycleBin_Click" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon 
                                        Kind="DeleteRestore" 
                                        Width="24" Height="24" 
                                        Margin="0,0,10,0"/>
                                    <TextBlock Text="Geri Dönüşüm Kutusu" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                    <Expander Header="Şifre İşlemleri" IsExpanded="False" Padding="0">
                        <StackPanel Margin="0,15,0,0">
                            <Grid Margin="0,0,0,10">
                                <PasswordBox x:Name="OldPasswordBox" materialDesign:HintAssist.Hint="Mevcut Şifre" 
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}" 
                                             VerticalAlignment="Center"/>
                                <TextBox x:Name="OldPasswordVisibleBox" materialDesign:HintAssist.Hint="Mevcut Şifre" 
                                         Visibility="Collapsed" VerticalAlignment="Center"/>
                                <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Width="32" Height="32" Margin="0,0,8,0"
                                              Click="ToggleOldPassword_Click">
                                    <materialDesign:PackIcon Kind="Eye" />
                                    <materialDesign:ToggleButtonAssist.OnContent>
                                        <materialDesign:PackIcon Kind="EyeOff" />
                                    </materialDesign:ToggleButtonAssist.OnContent>
                                </ToggleButton>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <PasswordBox x:Name="NewPasswordBox" materialDesign:HintAssist.Hint="Yeni Şifre" 
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}" 
                                             VerticalAlignment="Center"/>
                                <TextBox x:Name="NewPasswordVisibleBox" materialDesign:HintAssist.Hint="Yeni Şifre" 
                                         Visibility="Collapsed" VerticalAlignment="Center"/>
                                <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Width="32" Height="32" Margin="0,0,8,0"
                                              Click="ToggleNewPassword_Click">
                                    <materialDesign:PackIcon Kind="Eye" />
                                    <materialDesign:ToggleButtonAssist.OnContent>
                                        <materialDesign:PackIcon Kind="EyeOff" />
                                    </materialDesign:ToggleButtonAssist.OnContent>
                                </ToggleButton>
                            </Grid>
                            
                            <Button Content="ŞİFREYİ DEĞİŞTİR" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    BorderBrush="{DynamicResource PrimaryHueMidBrush}" Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                    HorizontalAlignment="Right" Click="ChangePassword_Click"/>
                        </StackPanel>
                    </Expander>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource DashboardCardStyle}">
                    <Border BorderBrush="#EF5350" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="Warning" Foreground="#EF5350" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Tehlikeli Bölge" FontWeight="Bold" Foreground="#EF5350" FontSize="16" VerticalAlignment="Center"/>
                            </DockPanel>
        
                            <TextBlock Text="Tüm finansal verilerinizi (İşlemler, Yatırımlar, Hedefler) kalıcı olarak siler." 
                                       TextWrapping="Wrap" 
                                       Margin="0,0,0,5" 
                                       Opacity="0.7"/>
                            
                            <Button Content="TÜM VERİLERİ SIFIRLA" 
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    BorderBrush="#EF5350" 
                                    Background="#EF5350" 
                                    Foreground="{DynamicResource MaterialDesignPaper}"
                                    HorizontalAlignment="Left" Click="ResetData_Click" Margin="0,0,0,20"/>

                            <Separator Margin="0,0,0,15"/>

                            <TextBlock Text="Hesabınızı ve tüm verilerinizi kalıcı olarak siler." 
                                       TextWrapping="Wrap" Margin="0,0,0,5" Opacity="0.7"/>
                            
                            <Button Content="HESABI KALICI OLARAK SİL" 
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#D32F2F" 
                                    BorderBrush="#D32F2F" 
                                    Foreground="{DynamicResource MaterialDesignPaper}"
                                    HorizontalAlignment="Left" Click="DeleteAccount_Click"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>