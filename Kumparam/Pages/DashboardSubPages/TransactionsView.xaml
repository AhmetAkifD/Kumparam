<UserControl x:Class="Kumparam.Pages.DashboardSubPages.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Margin="0,0,20,0" Padding="15" VerticalAlignment="Top" UniformCornerRadius="10">
            <StackPanel>
                <TextBlock Text="Yeni İşlem Ekle" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,15"/>

                <ComboBox x:Name="NewTypeCombo" materialDesign:HintAssist.Hint="İşlem Türü" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,10">
                    <ComboBoxItem Content="Gider (Harcama)" Tag="Expense" IsSelected="True"/>
                    <ComboBoxItem Content="Gelir (Para Girişi)" Tag="Income"/>
                </ComboBox>

                <TextBox x:Name="AmountBox" materialDesign:HintAssist.Hint="Tutar (₺)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <ComboBox x:Name="CategoryCombo" materialDesign:HintAssist.Hint="Kategori" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,10" IsEditable="True">
                    <ComboBoxItem Content="Market"/>
                    <ComboBoxItem Content="Fatura"/>
                    <ComboBoxItem Content="Ulaşım"/>
                    <ComboBoxItem Content="Yemek"/>
                    <ComboBoxItem Content="Eğlence"/>
                    <ComboBoxItem Content="Maaş"/>
                    <ComboBoxItem Content="Kira"/>
                    <ComboBoxItem Content="Diğer"/>
                </ComboBox>

                <DatePicker x:Name="TransactionDatePick" materialDesign:HintAssist.Hint="İşlem Tarihi" 
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,10"/>

                <TextBox x:Name="DescriptionBox" materialDesign:HintAssist.Hint="Açıklama (Opsiyonel)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <Button Content="KAYDET" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="0,15,0,0" Height="45" Click="SaveTransaction_Click"/>
            </StackPanel>
        </materialDesign:Card>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="0,0,0,15" Padding="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    
                    <DatePicker x:Name="StartDatePicker" Width="100" materialDesign:HintAssist.Hint="Başlangıç" Margin="0,0,10,0" SelectedDateChanged="Filter_Changed"/>
                    <DatePicker x:Name="EndDatePicker" Width="100" materialDesign:HintAssist.Hint="Bitiş" Margin="0,0,15,0" SelectedDateChanged="Filter_Changed"/>

                    <ComboBox x:Name="TypeComboBox" Width="100" materialDesign:HintAssist.Hint="Tür Filtre" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="Tümü" IsSelected="True"/>
                        <ComboBoxItem Content="Gelir"/>
                        <ComboBoxItem Content="Gider"/>
                    </ComboBox>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="TEMİZLE" Margin="15,0,0,0" Height="30" Padding="10,0" Click="ClearFilters_Click"/>
                </StackPanel>
            </materialDesign:Card>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="5" Margin="0,0,5,0" Padding="10">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="ArrowUpBold" Foreground="Green" VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Gelir" FontSize="10" Opacity="0.6"/>
                            <TextBlock x:Name="TotalIncomeText" Text="₺ 0,00" FontWeight="Bold" Foreground="Green"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFEBEE" CornerRadius="5" Margin="5,0,5,0" Padding="10">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="ArrowDownBold" Foreground="Red" VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Gider" FontSize="10" Opacity="0.6"/>
                            <TextBlock x:Name="TotalExpenseText" Text="₺ 0,00" FontWeight="Bold" Foreground="Red"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="5" Margin="5,0,0,0" Padding="10">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="ScaleBalance" Foreground="#1565C0" VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Net Fark" FontSize="10" Opacity="0.6"/>
                            <TextBlock x:Name="NetBalanceText" Text="₺ 0,00" FontWeight="Bold" Foreground="#1565C0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <DataGrid Grid.Row="2" x:Name="TransactionsGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tarih" Binding="{Binding TransactionDate, StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="100" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="Tutar" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Amount, StringFormat='{}{0:N2} ₺'}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat='+{0:N2} ₺'}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat='-{0:N2} ₺'}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Tag="{Binding TransactionId}" Click="DeleteTransaction_Click"
                                        ToolTip="Sil">
                                    <materialDesign:PackIcon Kind="Delete" Foreground="Red"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>