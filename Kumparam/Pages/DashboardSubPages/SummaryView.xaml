<UserControl x:Class="Kumparam.Pages.DashboardSubPages.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="900"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Başlık -->
            <RowDefinition Height="Auto"/> <!-- Kartlar -->
            <RowDefinition Height="*"/>    <!-- Alt Bölüm (Tablo ve Grafik) -->
        </Grid.RowDefinitions>

        <!-- 1. BAŞLIK -->
        <TextBlock Text="Finansal Özet" Style="{StaticResource HeaderTextStyle}"/>

        <!-- 2. BİLGİ KARTLARI (INFO CARDS) -->
        <Grid Grid.Row="1" Margin="0,10,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Kart 1: Toplam Bakiye -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <materialDesign:PackIcon Kind="Wallet" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" DockPanel.Dock="Left"/>
                        <TextBlock Text="Toplam Bakiye" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontWeight="SemiBold"/>
                    </DockPanel>
                    <!-- x:Name Verdik: TotalBalanceText -->
                    <TextBlock x:Name="TotalBalanceText" Text="₺ 0.00" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" Foreground="#2E7D32"/>
                    <TextBlock Text="Güncel durum" FontSize="11" Foreground="Green" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Kart 2: Bu Ay Gelir -->
            <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCardStyle}" Margin="10,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <materialDesign:PackIcon Kind="ArrowUpBoldCircle" Width="24" Height="24" Foreground="Green" DockPanel.Dock="Left"/>
                        <TextBlock Text="Bu Ay Gelir" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontWeight="SemiBold"/>
                    </DockPanel>
                    <!-- x:Name Verdik: MonthlyIncomeText -->
                    <TextBlock x:Name="MonthlyIncomeText" Text="₺ 0.00" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="Toplam giriş" FontSize="11" Opacity="0.5" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Kart 3: Bu Ay Gider -->
            <materialDesign:Card Grid.Column="2" Style="{StaticResource DashboardCardStyle}" Margin="10,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <materialDesign:PackIcon Kind="ArrowDownBoldCircle" Width="24" Height="24" Foreground="Red" DockPanel.Dock="Left"/>
                        <TextBlock Text="Bu Ay Gider" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontWeight="SemiBold"/>
                    </DockPanel>
                    <!-- x:Name Verdik: MonthlyExpenseText -->
                    <TextBlock x:Name="MonthlyExpenseText" Text="₺ 0.00" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="Toplam çıkış" FontSize="11" Opacity="0.5" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Kart 4: Tasarruf Hedefi (İleride dinamik olacak) -->
            <materialDesign:Card Grid.Column="3" Style="{StaticResource DashboardCardStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <materialDesign:PackIcon Kind="Target" Width="24" Height="24" Foreground="Orange" DockPanel.Dock="Left"/>
                        <TextBlock Text="Hedef İlerlemesi" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontWeight="SemiBold"/>
                    </DockPanel>
                    <!-- x:Name Verdik: SavingsProgressBar ve SavingsText -->
                    <ProgressBar x:Name="SavingsProgressBar" Value="0" Height="10" Margin="0,15,0,5" Foreground="Orange" Background="#EEE"/>
                    <TextBlock x:Name="SavingsText" Text="%0 Tamamlandı" FontSize="11" Opacity="0.5" HorizontalAlignment="Right"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- 3. ALT BÖLÜM (LİSTE VE GRAFİK ALANI) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/> <!-- Sol (Geniş) -->
                <ColumnDefinition Width="1*"/> <!-- Sağ (Dar) -->
            </Grid.ColumnDefinitions>

            <!-- Sol: Son İşlemler Listesi -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Liste Başlığı -->
                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBlock Text="Son İşlemler" Style="{StaticResource HeaderTextStyle}" Margin="0"/>
                        <Button Content="Tümünü Gör" Style="{StaticResource MaterialDesignFlatButton}" Height="Auto" Padding="10,5" DockPanel.Dock="Right"/>
                    </DockPanel>

                    <!-- Buraya ileride DataGrid veya ItemsControl gelecek. Şimdilik placeholder. -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Henüz işlem yok." Opacity="0.5" HorizontalAlignment="Center" Margin="20"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- Sağ: Grafik Alanı (Placeholder) -->
            <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Harcama Dağılımı" Style="{StaticResource HeaderTextStyle}"/>

                    <Grid Grid.Row="1">
                        <TextBlock x:Name="NoDataText" Text="Henüz harcama verisi yok." 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Opacity="0.5" Visibility="Collapsed"/>

                        <lvc:PieChart x:Name="ExpensePieChart" 
                                      LegendPosition="Bottom"
                                      TooltipPosition="Top">
                        </lvc:PieChart>
                    </Grid>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>