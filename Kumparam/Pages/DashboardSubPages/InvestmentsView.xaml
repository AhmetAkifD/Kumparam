<UserControl x:Class="Kumparam.Pages.DashboardSubPages.InvestmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="2*"/>   </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Yeni Yatırım Ekle" Style="{StaticResource HeaderTextStyle}"/>

                <ComboBox x:Name="InvestmentComboBox" 
                          materialDesign:HintAssist.Hint="Yatırım Aracı Seçin"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          Margin="0,10"
                          SelectionChanged="InvestmentComboBox_SelectionChanged"/>

                <TextBox x:Name="SymbolTextBox" 
                         materialDesign:HintAssist.Hint="Sembol (Otomatik)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,10"
                         IsReadOnly="True" 
                         Background="#F0F0F0"/>

                <TextBox x:Name="QuantityTextBox" materialDesign:HintAssist.Hint="Miktar / Adet" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <TextBox x:Name="BuyingPriceTextBox" materialDesign:HintAssist.Hint="Birim Alış Fiyatı (₺)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <DatePicker x:Name="PurchaseDatePicker" materialDesign:HintAssist.Hint="Alış Tarihi" 
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,10"/>

                <Button Content="PORTFÖYE EKLE" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="0,20,0,0" Height="50" Click="SaveInvestment_Click"/>
            </StackPanel>
        </materialDesign:Card>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Portföyüm" Style="{StaticResource HeaderTextStyle}" Margin="5,0,0,10"/>

                <ItemsControl x:Name="InvestmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,15" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                                    <Viewbox Width="32" Height="32" Margin="0,0,15,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="ChartLine" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </Viewbox>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                        
                                        <StackPanel Orientation="Horizontal" Opacity="0.7" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0:N2} Adet'}" />
                                            <TextBlock Text=" x " Margin="5,0"/>
                                            <TextBlock Text="{Binding BuyingPrice, StringFormat='{}{0:N2} ₺'}"/>
                                            <TextBlock Text=" (Maliyet)" FontSize="10" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding Symbol}" FontSize="10" Opacity="0.5" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="Toplam Değer" FontSize="10" Opacity="0.6" HorizontalAlignment="Right"/>
                                        
                                        <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N2} ₺'}" 
                                                   FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding ProfitLossAmount, StringFormat='{}{0:N2} ₺'}" 
                                                       Foreground="Gray" FontWeight="SemiBold"/>
                                            
                                            <TextBlock Text="{Binding ProfitLossPercentage, StringFormat=' (%{0:0.00})'}" 
                                                       Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>