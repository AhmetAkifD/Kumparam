<UserControl x:Class="Kumparam.Pages.DashboardSubPages.InvestmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Kumparam.Pages.DashboardSubPages"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <UserControl.Resources>
        <local:FirstCharConverter x:Key="FirstCharConverter"/>
        <local:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Yeni Yatırım Ekle" Style="{StaticResource HeaderTextStyle}"/>
                <ComboBox x:Name="BankSourceComboBox" 
                          materialDesign:HintAssist.Hint="Banka / Kaynak Seçimi"
                          Margin="0,10"
                          SelectionChanged="BankSourceComboBox_SelectionChanged">
                    <ComboBoxItem Content="Diğer Siteler (Web)" Tag="Web" IsSelected="True"/>
                    <ComboBoxItem Content="Ziraat Bankası" Tag="ZiraatBankasi"/>
                    <ComboBoxItem Content="Halkbank" Tag="Halkbank"/>
                    <ComboBoxItem Content="Yapı Kredi Bankası" Tag="YapiKrediBankasi"></ComboBoxItem>
                </ComboBox>
                <ComboBox x:Name="InvestmentComboBox" 
                          materialDesign:HintAssist.Hint="Yatırım Aracı"
                          Margin="0,10"
                          SelectionChanged="InvestmentComboBox_SelectionChanged"/>

                <TextBox x:Name="SymbolTextBox" 
                         materialDesign:HintAssist.Hint="Sembol" 
                         Margin="0,10"
                         IsReadOnly="True" 
                         Opacity="0.7"
                         Background="{DynamicResource MaterialDesignPaper}"
                         Foreground="{DynamicResource MaterialDesignBody}"
                         /> 
                <TextBox x:Name="CurrentPriceTextBox" 
                         materialDesign:HintAssist.Hint="Anlık Alış Kuru (Birim Fiyat)" 
                         Margin="0,10"
                         IsReadOnly="True" 
                         FontWeight="Bold"
                         Opacity="0.7"
                         Foreground="{DynamicResource MaterialDesignBody}"
                         Background="{DynamicResource MaterialDesignPaper}"
                         />

                <TextBox x:Name="QuantityTextBox" materialDesign:HintAssist.Hint="Miktar" 
                         Margin="0,10"/>

                <DatePicker x:Name="PurchaseDatePicker" materialDesign:HintAssist.Hint="Alış Tarihi" 
                            Margin="0,10"/>

                <Button Content="PORTFÖYE EKLE" 
                        Margin="0,20,0,0" Height="50" Click="SaveInvestment_Click"/>
            </StackPanel>
        </materialDesign:Card>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Wallet" Width="25" Height="25" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="PORTFÖYÜM" Style="{StaticResource HeaderTextStyle}" Margin="0" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                        <materialDesign:PackIcon Kind="ClockTimeFourOutline" Width="16" Height="16" VerticalAlignment="Center" Opacity="0.5"/>
                        <TextBlock x:Name="TxtLastUpdate" Text="Güncel" FontSize="12" Opacity="0.5" FontStyle="Italic" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Click="BtnRefresh_Click" Height="30" Padding="10,0"
                        ToolTip="Fiyatları İnternetten Güncelle">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,5,0" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="YENİLE" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <Border BorderBrush="#42A5F5" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <materialDesign:PackIcon Kind="Safe" Foreground="#42A5F5" VerticalAlignment="Center"/>
                                <TextBlock Text="Toplam Portföy" FontSize="12" Opacity="0.7" Margin="5,0,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </DockPanel>
                            <TextBlock x:Name="HeaderTotalValueText" Text="0,00 ₺" FontSize="20" FontWeight="Bold" Foreground="#42A5F5" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Margin="5,0,5,0" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <materialDesign:PackIcon Kind="CreditCardOutline" Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                                <TextBlock Text="Toplam Maliyet" FontSize="12" Opacity="0.7" Margin="5,0,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </DockPanel>
                            <TextBlock x:Name="HeaderTotalCostText" Text="0,00 ₺" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Margin="10,0,0,0" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <Border BorderBrush="#66BB6A" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <materialDesign:PackIcon Kind="ChartLineVariant" Foreground="#66BB6A" VerticalAlignment="Center"/>
                                <TextBlock Text="Genel Durum" FontSize="12" Opacity="0.7" Margin="5,0,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </DockPanel>
                            <TextBlock x:Name="HeaderTotalProfitText" Text="0,00 ₺" FontSize="20" FontWeight="Bold" Foreground="#66BB6A" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>

            <ListView Grid.Row="2" x:Name="PortfolioGrid"
                      ItemsSource="{Binding PortfolioItems}" 
                      HorizontalContentAlignment="Stretch" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent" BorderThickness="0">
                
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,5,10" Padding="15" Background="{DynamicResource MaterialDesignPaper}" UniformCornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>   
                                    <ColumnDefinition Width="1.2*"/> 
                                    <ColumnDefinition Width="1.5*"/> 
                                    <ColumnDefinition Width="1.5*"/> 
                                    <ColumnDefinition Width="1.5*"/> 
                                    <ColumnDefinition Width="Auto"/> 
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource MaterialDesignBody}"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                    
                                    <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="4" HorizontalAlignment="Left" Padding="5,2" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding Symbol}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignBody}" Opacity="0.7"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Adet" FontSize="10" Opacity="0.6"/>
                                    <TextBlock Text="{Binding TotalQuantity, StringFormat='{}{0:N2}'}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="Toplam Maliyet" FontSize="10" Opacity="0.6"/>
                                    <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N2} ₺'}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="Toplam Değer" FontSize="10" Opacity="0.6"/>
                                    <TextBlock FontWeight="Bold" FontSize="16">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="--- ₺"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPriceLoaded}" Value="True">
                                                        <Setter Property="Text" Value="{Binding CurrentValue, StringFormat='{}{0:N2} ₺'}"/>
                                                        <Setter Property="Foreground" Value="#42A5F5"/> </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="4" VerticalAlignment="Center" 
                                            Visibility="{Binding IsPriceLoaded, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Net Durum" FontSize="10" Opacity="0.6"/>
                                    
                                    <TextBlock FontWeight="Bold" FontSize="15" 
                                               Text="{Binding ProfitLossAmount, StringFormat='{}{0:N2} ₺'}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ProfitLossAmount, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="#EF5350"/> </DataTrigger>
                                                    <DataTrigger Binding="{Binding ProfitLossAmount, Converter={StaticResource IsNegativeConverter}}" Value="False">
                                                        <Setter Property="Foreground" Value="#66BB6A"/> </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <TextBlock FontSize="11" Opacity="0.8" Foreground="{DynamicResource MaterialDesignBody}"
                                               Text="{Binding ProfitLossPercent, StringFormat='( %{0:N2} )'}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Tag="{Binding}" Click="DeleteGroup_Click"
                                            ToolTip="Kaydı Sil (İade Et)"
                                            Width="35" Height="35" Margin="0,0,5,0">
                                        <materialDesign:PackIcon Kind="Delete" Foreground="#EF5350" Width="20" Height="20"/>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Tag="{Binding}" Click="SellGroup_Click"
                                            ToolTip="Satış Yap / Bozdur"
                                            Width="35" Height="35">
                                        <materialDesign:PackIcon Kind="HandCoin" Foreground="#66BB6A" Width="24" Height="24"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>