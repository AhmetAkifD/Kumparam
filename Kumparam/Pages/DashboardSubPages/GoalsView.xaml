<UserControl x:Class="Kumparam.Pages.DashboardSubPages.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Yeni Hedef Oluştur" Style="{StaticResource HeaderTextStyle}"/>

                <TextBox x:Name="TitleTextBox" materialDesign:HintAssist.Hint="Hedef Başlığı" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <TextBox x:Name="TargetAmountTextBox" materialDesign:HintAssist.Hint="Hedeflenen Tutar (₺)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                <TextBox x:Name="CurrentAmountTextBox" materialDesign:HintAssist.Hint="Şu Anki Birikim (Varsa)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10" Text="0"/>

                <DatePicker x:Name="DeadlineDatePicker" materialDesign:HintAssist.Hint="Hedef Tarih (Opsiyonel)" 
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,10"/>

                <TextBox x:Name="DescriptionTextBox" materialDesign:HintAssist.Hint="Açıklama / Notlar" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         KeyDown="DescriptionTextBox_OnKeyDown"/>

                <Button Content="HEDEFİ KAYDET" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="0,20,0,0" Height="50" Click="SaveGoal_Click"/>
            </StackPanel>
        </materialDesign:Card>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Hedeflerim" Style="{StaticResource HeaderTextStyle}" Margin="5,0,0,10"/>

                <ItemsControl x:Name="GoalsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,15" Padding="15">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" Foreground="Black" 
                                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                        
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    ToolTip="Para Ekle"
                                                    Margin="5,0"
                                                    Tag="{Binding}"
                                                    Click="AddMoney_Click">
                                                <materialDesign:PackIcon Kind="CashPlus" Foreground="Green" Width="24" Height="24"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    ToolTip="Sil"
                                                    Margin="5,0"
                                                    Tag="{Binding}"  Click="DeleteGoal_Click">
                                                <materialDesign:PackIcon Kind="Delete" Foreground="Red" Width="24" Height="24"/>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                            
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="Birikim: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CurrentAmount}" Foreground="Green"/>
                                        <TextBlock Text=" / Hedef: " FontWeight="Bold" Margin="10,0,0,0"/>
                                        <TextBlock Text="{Binding TargetAmount}" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}İlerleme: %{0:0.0}'}" Foreground="Orange" FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd/MM/yyyy}'}" Opacity="0.5" Margin="0,5,0,0"/>
                            
                                    <TextBlock Text="{Binding Description}" FontStyle="Italic" Opacity="0.6"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>