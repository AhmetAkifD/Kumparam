<UserControl x:Class="Kumparam.Pages.DashboardSubPages.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Kumparam.Pages.DashboardSubPages"
             xmlns:models="clr-namespace:Kumparam.Core.Models;assembly=Kumparam.Core"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <UserControl.Resources>
        <local:DeadlineToRemainingDaysConverter x:Key="DeadlineToRemainingDaysConverter"/>
        <local:DeadlineToColorConverter x:Key="DeadlineToColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Margin="0,0,20,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="🎯 Yeni Hedef" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,15"/>

                <TextBox x:Name="TitleTextBox" materialDesign:HintAssist.Hint="Hedef Başlığı" 
                         Margin="0,10"/>

                <TextBox x:Name="TargetAmountTextBox" materialDesign:HintAssist.Hint="Hedeflenen Tutar (₺)" 
                         Margin="0,10"/>

                <TextBox x:Name="CurrentAmountTextBox" materialDesign:HintAssist.Hint="Başlangıç Tutarı (Opsiyonel)" 
                         Margin="0,10" Text="0"/>

                <DatePicker x:Name="DeadlineDatePicker" materialDesign:HintAssist.Hint="Hedef Tarih" 
                            Margin="0,10"/>

                <TextBox x:Name="DescriptionTextBox" materialDesign:HintAssist.Hint="Notlar..." 
                         Margin="0,10"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         KeyDown="DescriptionTextBox_OnKeyDown"/>

                <Button Content="KAYDET"
                        Margin="0,20,0,0" Height="45" Click="SaveGoal_Click"
                        materialDesign:ButtonAssist.CornerRadius="5"/>
            </StackPanel>
        </materialDesign:Card>

        <Border Grid.Column="1" Background="Transparent" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Mevcut Hedefler" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="5,0,0,15"/>

                    <ItemsControl x:Name="GoalsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0" LastChildFill="False">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" DockPanel.Dock="Left"/>

                                            <TextBlock Text="{Binding Deadline, StringFormat='{}{0:dd.MM.yyyy}'}" 
                                                       FontSize="12" Opacity="0.6" VerticalAlignment="Center" DockPanel.Dock="Right"/>

                                            <TextBlock Text="{Binding Deadline, Converter={StaticResource DeadlineToRemainingDaysConverter}}" 
                                                       Foreground="{Binding Deadline, Converter={StaticResource DeadlineToColorConverter}}"
                                                       FontSize="12" FontWeight="Bold" 
                                                       VerticalAlignment="Center" Margin="0,0,10,0" DockPanel.Dock="Right"/>
                                        </DockPanel>

                                        <Grid Grid.Row="1" Margin="0,15,0,5">
                                            <ProgressBar Value="{Binding CurrentAmount}" Maximum="{Binding TargetAmount}" Height="15" 
                                                         Background="{DynamicResource MaterialDesignDivider}" 
                                                         Foreground="#FFA726" 
                                                         BorderBrush="Transparent" BorderThickness="0"/>
                                        </Grid>

                                        <DockPanel Grid.Row="2" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding CurrentAmount, StringFormat='{}{0:N0} ₺'}" FontWeight="Bold" Foreground="#66BB6A"/>
                                                <TextBlock Text=" / " Opacity="0.5"/>
                                                <TextBlock Text="{Binding TargetAmount, StringFormat='{}{0:N0} ₺'}" Opacity="0.7"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}%{0:0.0}'}" 
                                                       DockPanel.Dock="Right" FontWeight="Bold" Foreground="#FFA726"/>
                                        </DockPanel>

                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Description}" 
                                                           FontSize="11" Opacity="0.6" 
                                                           FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,10,5"/>

                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CalendarClock" VerticalAlignment="Center" Width="14" Height="14" Foreground="Teal"/>
                                                    <TextBlock Text="Hesaplanıyor..." x:Name="EstimationTextBlock"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="Teal" Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                                        ToolTip="Otomatik Birikim Kur"
                                                        Tag="{Binding}" Click="AutoSave_Click"
                                                        Foreground="Teal"
                                                        Width="36" Height="36" Margin="0,0,2,0">
                                                    <materialDesign:PackIcon Kind="Autorenew" Width="24" Height="24"/>
                                                </Button>
                                                <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Para Ekle" Tag="{Binding}" Click="AddMoney_Click" Foreground="#66BB6A" Width="36" Height="36" Margin="0,0,2,0">
                                                    <materialDesign:PackIcon Kind="CashPlus" Width="24" Height="24"/>
                                                </Button>
                                                <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Para Çek" Tag="{Binding}" Click="RemoveMoney_Click" Foreground="#EF5350" Width="36" Height="36" Margin="0,0,2,0">
                                                    <materialDesign:PackIcon Kind="CashMinus" Width="24" Height="24"/>
                                                </Button>
                                                <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Sil" Tag="{Binding}" Click="DeleteGoal_Click" Foreground="#EF5350" Width="36" Height="36">
                                                    <materialDesign:PackIcon Kind="Delete" Width="24" Height="24"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>