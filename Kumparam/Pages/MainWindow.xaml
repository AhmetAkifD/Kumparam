<Window x:Class="Kumparam.Pages.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kumparam"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Title="Kumparam'a Hoş Geldin" Height="555" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid x:Name="MainGrid">
        <Grid x:Name="LoginGrid" Background="Transparent">
            <Grid.RenderTransform>
                <TranslateTransform X="0" />
            </Grid.RenderTransform>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="Giriş Yap" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"/>

                <TextBox x:Name="EmailTextBox" materialDesign:HintAssist.Hint="E-posta Adresi" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,10"/>

                <Grid Margin="0,10">
                    <PasswordBox x:Name="SifrePasswordBox"
                                 materialDesign:HintAssist.Hint="Şifre"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 KeyDown="Password_KeyDown"
                                 VerticalAlignment="Center" />

                    <TextBox x:Name="SifreAcikTextBox"
                             materialDesign:HintAssist.Hint="Şifre"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"/>

                    <ToggleButton x:Name="SifreGosterGizleButton"
                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Width="32" Height="32"
                                  Margin="0,0,8,0"
                                  Click="SifreGosterGizle_Click">
                        <materialDesign:PackIcon Kind="Eye" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="EyeOff" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                </Grid>
                <Button Content="Giriş Yap" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,20,0,10"
                        Click="Login_Button_Click"/>
                
                <TextBlock x:Name="DbConnectionStatusTextBlock"
                           Text="Veritabanı bağlantısı kontrol ediliyor..."
                           Foreground="Gray"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0" />

                <TextBlock x:Name="HataMesajiTextBlock"
                           Text="E-posta veya şifre hatalı!"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"
                           Visibility="Collapsed" />

                <Button Content="Hesabın yok mu? Kayıt ol." 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="Gray"
                        Click="KayitEkraniniGoster_Click"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="RegisterGrid" Background="Transparent" Visibility="Collapsed">
            <Grid.RenderTransform>
                <TranslateTransform X="0" />
            </Grid.RenderTransform>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="Kayıt Ol" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"/>

                <TextBox materialDesign:HintAssist.Hint="İsim"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,10"
                         Name="Register_IsimTextBox"/>

                <TextBox materialDesign:HintAssist.Hint="Soyisim"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,10"
                         Name="Register_SoyisimTextBox"/>

                <TextBox materialDesign:HintAssist.Hint="E-posta Adresi" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,10"
                         Name="Register_EmailTextBox"/>

                <Grid Margin="0,10">
                    <PasswordBox materialDesign:HintAssist.Hint="Şifre" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" 
                                 Name="Register_SifrePasswordBox"
                                 VerticalAlignment="Center"/>

                    <TextBox materialDesign:HintAssist.Hint="Şifre"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Name="Register_SifreAcikTextBox"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"/>

                    <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Width="32" Height="32" Margin="0,0,8,0"
                                  Click="Register_SifreGoster_Click"> <materialDesign:PackIcon Kind="Eye" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="EyeOff" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                </Grid>
                <Grid Margin="0,10">
                    <PasswordBox materialDesign:HintAssist.Hint="Şifre Tekrar" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" 
                                 Name="Register_SifreTekrarPasswordBox"
                                 KeyDown="PasswordAgain_KeyDown"
                                 VerticalAlignment="Center"/>

                    <TextBox materialDesign:HintAssist.Hint="Şifre Tekrar"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Name="Register_SifreTekrarAcikTextBox"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"/>

                    <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Width="32" Height="32" Margin="0,0,8,0"
                                  Click="Register_SifreTekrarGoster_Click"> <materialDesign:PackIcon Kind="Eye" />
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="EyeOff" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                </Grid>
                <Button Content="Hesap Oluştur" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,20,0,10"
                        Click="Register_Button_Click"/>

                <Button Content="Zaten hesabın var mı? Giriş yap." 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="Gray"
                        Click="GirisEkraniniGoster_Click"/>
            </StackPanel>
        </Grid>
        <ToggleButton x:Name="ThemeToggle"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="20"
                      Style="{StaticResource MaterialDesignActionToggleButton}"
                      Click="ThemeToggle_Click">
            <ToggleButton.Content>
                <materialDesign:PackIcon Kind="WeatherNight" Width="25" Height="25" Foreground="#FDB813"/>
            </ToggleButton.Content>
            <materialDesign:ToggleButtonAssist.OnContent>
                <materialDesign:PackIcon Kind="WeatherSunny" Width="25" Height="25" Foreground="#673AB7"/> </materialDesign:ToggleButtonAssist.OnContent>
        </ToggleButton>
    </Grid>
</Window>